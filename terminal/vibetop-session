#!/usr/bin/python3
"""Lightweight session persistence daemon for ttyd terminals.

Replaces tmux with a transparent PTY bridge that preserves xterm.js scrollback.
Two modes:
  vibetop-session serve N   — daemon: holds bash in a PTY, accepts client connections
  vibetop-session attach N  — client: bridges ttyd's PTY to the daemon's socket
"""

import argparse, errno, fcntl, os, random, re, select, selectors, signal, socket, struct, sys, termios, time


class RingBuffer:
    """Fixed-size circular byte buffer."""

    def __init__(self, capacity):
        self._buf = bytearray(capacity)
        self._cap = capacity
        self._pos = 0
        self._len = 0

    def write(self, data):
        n = len(data)
        if n >= self._cap:
            data = data[-self._cap:]
            n = self._cap
            self._buf[:] = data
            self._pos = 0
            self._len = self._cap
            return
        end = self._pos + n
        if end <= self._cap:
            self._buf[self._pos:end] = data
        else:
            first = self._cap - self._pos
            self._buf[self._pos:] = data[:first]
            self._buf[:n - first] = data[first:]
        self._pos = end % self._cap
        self._len = min(self._len + n, self._cap)

    def read_all(self):
        if self._len == 0:
            return b''
        start = (self._pos - self._len) % self._cap
        if start + self._len <= self._cap:
            return bytes(self._buf[start:start + self._len])
        first = self._cap - start
        return bytes(self._buf[start:]) + bytes(self._buf[:self._len - first])

    def clear(self):
        self._pos = 0
        self._len = 0


# Terminal *query-request* escape sequences — the ones the emulator must ANSWER:
#   CSI … c        Device Attributes        (DA1/DA2/DA3)   answered with CSI … c
#   CSI … n        Device/Cursor Status     (DSR/CPR)       answered with CSI … R / … n
#   CSI … $p       Request Mode             (DECRQM)        answered with CSI … $y
#   OSC … ; ? ST   color/palette query      (OSC 10/11/12/4) answered with OSC … ; rgb:…
# These belong in the LIVE stream (answered once, by whoever asked) but NOT in the
# ring-buffer replay: replaying a stale query to a freshly (re)connected xterm.js
# makes it re-answer, and that answer lands in the shared PTY's input and is echoed
# at the prompt as garbage like "0;276;0c10;rgb:…11;rgb:…$y". With a shared session
# (multi-client broadcast) and vibetop's frequent reconnects, one old query can be
# re-answered on every reconnect. Stripping query REQUESTS from the replay stops it;
# color/cursor *set* sequences (real screen state, e.g. OSC 11;rgb:… with no '?') are
# left intact. See docs/design-decisions.md.
_QUERY_REQUEST_RE = re.compile(
    rb'\x1b\[[0-9;?>=]*c'              # DA request (primary/secondary/tertiary)
    rb'|\x1b\[[0-9;?]*n'              # DSR / cursor-position request
    rb'|\x1b\[[0-9;?]*\$p'           # DECRQM (request mode)
    rb'|\x1b\][0-9;]*\?(?:\x07|\x1b\\)'   # OSC color/palette query (the ';?' form)
)


def strip_terminal_queries(data):
    """Remove terminal query-REQUEST sequences (DA/DSR/CPR/DECRQM/OSC-color '?')
    from `data`. Used only on the ring-buffer replay sent to a new client, so a
    reconnect never re-triggers a query answer that would be echoed at the prompt.
    Pure — unit-tested in terminal/tests/test_claude_session.py."""
    return _QUERY_REQUEST_RE.sub(b'', data)


def set_pty_size(fd, rows, cols):
    fcntl.ioctl(fd, termios.TIOCSWINSZ, struct.pack('HHHH', rows, cols, 0, 0))


def get_pty_size(fd):
    buf = fcntl.ioctl(fd, termios.TIOCGWINSZ, b'\x00' * 8)
    return struct.unpack('HHHH', buf)[:2]


def set_nonblock(fd):
    flags = fcntl.fcntl(fd, fcntl.F_GETFL)
    fcntl.fcntl(fd, fcntl.F_SETFL, flags | os.O_NONBLOCK)


def write_all(fd, data):
    """Write every byte of `data` to a blocking fd, looping over short writes
    and EINTR. A bare os.write() can return fewer bytes than given (signals,
    large buffers), and dropping the remainder silently corrupts/truncates the
    terminal stream — which on the replay-on-connect burst looks like 'content
    didn't fully load.'"""
    mv = memoryview(data)
    while mv:
        try:
            n = os.write(fd, mv)
        except InterruptedError:
            continue
        mv = mv[n:]


# ---------------------------------------------------------------------------
# serve
# ---------------------------------------------------------------------------

def cmd_serve(instance):
    sock_path = f'/tmp/vibetop-session-{instance}.sock'
    pid_path = f'/tmp/vibetop-session-{instance}.pid'
    size_path = f'/tmp/vibetop-session-{instance}.size'
    buf_cap = int(os.environ.get('CLAUDE_SESSION_BUFSIZE', 256 * 1024))

    ring = RingBuffer(buf_cap)
    clients = {}          # fileno -> socket
    client_outq = {}      # fileno -> bytearray (pending output)
    pty_fd = -1
    child_pid = 0
    sel = selectors.DefaultSelector()
    MAX_OUTQ = 1024 * 1024
    # Resize debounce: a SIGUSR1 (an attach client's size changed) doesn't apply
    # the resize inline — it arms a deadline, and the main loop applies the LATEST
    # saved size once things go quiet. This collapses a rapid burst of resizes into
    # a single TIOCSWINSZ + SIGWINCH, so the shell redraws once at the final size.
    # Without it, the desktop "re-claim shape" gesture (which nudges the size to a
    # neighbour and back to force a SIGWINCH) made the shell redraw at the
    # intermediate size first — a visible one-off "shake".
    RESIZE_DEBOUNCE = 0.035
    pending_resize = False
    resize_deadline = 0.0
    # Respawn backoff: if a freshly-spawned shell dies almost immediately
    # (e.g. /bin/bash missing or unexecutable), respawning instantly is a tight
    # fork loop that pins a CPU. Track when the current shell started and how
    # many quick deaths in a row we've seen.
    last_spawn = 0.0
    respawn_fails = 0

    # -- helpers --

    def read_saved_size():
        try:
            with open(size_path) as f:
                parts = f.read().split()
            rows, cols = int(parts[0]), int(parts[1])
        except Exception:
            return 24, 80
        # Clamp: the size file lives at a predictable /tmp path and is written by
        # the attach client, so a garbage or out-of-range value (negative, or
        # above the unsigned-short TIOCSWINSZ limit) would raise struct.error in
        # set_pty_size and crash the daemon — losing the session. Bound it to
        # sane terminal dimensions.
        rows = min(9999, max(1, rows))
        cols = min(9999, max(1, cols))
        return rows, cols

    def spawn_shell():
        nonlocal pty_fd, child_pid, last_spawn
        last_spawn = time.monotonic()
        master, slave = os.openpty()
        rows, cols = read_saved_size()
        set_pty_size(master, rows, cols)
        pid = os.fork()
        if pid == 0:
            # Child: must never return into the parent's serve loop. If anything
            # here (incl. execv on a missing /bin/bash) raises, _exit hard
            # instead of falling through and becoming a second daemon.
            try:
                os.close(master)
                os.setsid()
                fcntl.ioctl(slave, termios.TIOCSCTTY, 0)
                os.dup2(slave, 0)
                os.dup2(slave, 1)
                os.dup2(slave, 2)
                if slave > 2:
                    os.close(slave)
                os.environ['TERM'] = os.environ.get('TERM', 'xterm-256color')
                os.environ['LANG'] = os.environ.get('LANG', 'en_US.UTF-8')
                os.environ['TERM_ID'] = str(instance)
                os.execv('/bin/bash', ['bash', '-l'])
            except BaseException:
                os._exit(127)
        os.close(slave)
        set_nonblock(master)
        pty_fd = master
        child_pid = pid
        sel.register(pty_fd, selectors.EVENT_READ, 'pty')

    def remove_client(fd):
        try:
            sel.unregister(fd)
        except Exception:
            pass
        sock = clients.pop(fd, None)
        client_outq.pop(fd, None)
        if sock:
            try:
                sock.close()
            except Exception:
                pass

    def broadcast(data):
        dead = []
        for fd, sock in clients.items():
            q = client_outq.get(fd)
            if q:
                q.extend(data)
                if len(q) > MAX_OUTQ:
                    dead.append(fd)
                continue
            try:
                sent = sock.send(data)
                if sent < len(data):
                    client_outq[fd] = bytearray(data[sent:])
            except (BlockingIOError, InterruptedError):
                client_outq[fd] = bytearray(data)
            except Exception:
                dead.append(fd)
        for fd in dead:
            remove_client(fd)

    def flush_client_outq(fd):
        q = client_outq.get(fd)
        if not q:
            return
        sock = clients.get(fd)
        if not sock:
            return
        try:
            sent = sock.send(q)
            if sent >= len(q):
                del client_outq[fd]
            else:
                client_outq[fd] = q[sent:]
        except (BlockingIOError, InterruptedError):
            pass
        except Exception:
            remove_client(fd)

    def reap_child():
        nonlocal child_pid, pty_fd
        if child_pid <= 0:
            return False
        try:
            pid, _ = os.waitpid(child_pid, os.WNOHANG)
        except ChildProcessError:
            pid = child_pid
        if pid == 0:
            return False
        try:
            sel.unregister(pty_fd)
        except Exception:
            pass
        try:
            os.close(pty_fd)
        except Exception:
            pass
        pty_fd = -1
        child_pid = 0
        return True

    # -- signal handlers --

    def apply_resize():
        # Apply the latest saved size to the shared PTY once (called from the main
        # loop after the debounce window, not inline in the signal handler).
        nonlocal pending_resize
        pending_resize = False
        if pty_fd < 0:
            return
        try:
            rows, cols = read_saved_size()
            set_pty_size(pty_fd, rows, cols)
            if child_pid > 0:
                os.kill(child_pid, signal.SIGWINCH)
        except Exception:
            pass

    def on_sigusr1(signum, frame):
        # Just arm the debounce; the main loop applies the resize once it's quiet.
        nonlocal pending_resize, resize_deadline
        pending_resize = True
        resize_deadline = time.monotonic() + RESIZE_DEBOUNCE

    def on_sigterm(signum, frame):
        # Hang up the shell rather than SIGTERM it (interactive bash ignores
        # SIGTERM anyway). SIGHUP is the terminal-hangup signal: bash forwards it
        # to its jobs and exits, while setsid'd daemons (ssh ControlPersist master,
        # tmux, nohup) are in their own session and survive — exactly like closing
        # a real terminal. Paired with KillMode=process on the unit (so systemd
        # doesn't then SIGKILL the whole cgroup). Closing the PTY on exit (below)
        # would also raise SIGHUP, but signalling explicitly is immediate/robust.
        if child_pid > 0:
            try:
                os.kill(child_pid, signal.SIGHUP)
            except Exception:
                pass
        for fd in list(clients):
            remove_client(fd)
        try:
            os.unlink(sock_path)
        except Exception:
            pass
        try:
            os.unlink(pid_path)
        except Exception:
            pass
        sys.exit(0)

    signal.signal(signal.SIGUSR1, on_sigusr1)
    signal.signal(signal.SIGTERM, on_sigterm)

    # -- setup --

    def make_listener():
        # (Re)create the Unix socket + pid file. Called at startup and again by
        # the watchdog in the main loop if the socket file is ever deleted or
        # replaced out from under us (e.g. a stray `rm` in /tmp). Without this
        # the daemon would keep listening on an orphaned in-kernel socket whose
        # filesystem path is gone — unreachable by attach, recoverable only by a
        # session-killing restart.
        try:
            os.unlink(sock_path)
        except FileNotFoundError:
            pass
        s = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
        # Create the socket already restricted (no group/other) — bind() honours
        # the umask, so without this there's a window between bind and chmod where
        # the predictable /tmp socket is connectable by other local users.
        old_umask = os.umask(0o177)
        try:
            s.bind(sock_path)
        finally:
            os.umask(old_umask)
        os.chmod(sock_path, 0o600)
        s.listen(5)
        s.setblocking(False)
        # Write the pid via O_NOFOLLOW (+ unlink first): the path is predictable
        # and in world-writable /tmp, so a pre-planted symlink must not get this
        # write redirected (truncating an arbitrary file the daemon can reach).
        try:
            os.unlink(pid_path)
        except FileNotFoundError:
            pass
        pid_fd = os.open(pid_path,
                         os.O_WRONLY | os.O_CREAT | os.O_TRUNC | os.O_NOFOLLOW, 0o600)
        with os.fdopen(pid_fd, 'w') as f:
            f.write(str(os.getpid()))
        return s

    def sock_sig():
        # (dev, inode) of the on-disk socket file, or None if it's gone. A
        # changed/missing signature means the path is no longer our listener.
        try:
            st = os.stat(sock_path)
        except OSError:
            return None
        return (st.st_dev, st.st_ino)

    server = make_listener()
    server_sig = sock_sig()
    sel.register(server, selectors.EVENT_READ, 'server')

    spawn_shell()

    # -- main loop --

    next_heal = 0.0
    while True:
        # Watchdog: if our socket file disappeared or was replaced, re-bind it
        # (and rewrite the pid file) so the daemon self-heals instead of becoming
        # an unreachable orphan. Throttled to ~1s; existing attached clients are
        # on their own accepted sockets and are unaffected by the re-bind.
        now = time.monotonic()
        if now >= next_heal:
            next_heal = now + 1.0
            if sock_sig() != server_sig:
                try:
                    sel.unregister(server)
                except Exception:
                    pass
                try:
                    server.close()
                except Exception:
                    pass
                server = make_listener()
                server_sig = sock_sig()
                sel.register(server, selectors.EVENT_READ, 'server')

        if reap_child():
            ring.clear()
            # If the shell barely lived, back off before respawning so a shell
            # that can't start (missing/unexecutable /bin/bash) can't spin into a
            # tight fork loop. Capped exponential backoff + jitter; reset once a
            # shell survives long enough to be considered healthy.
            if time.monotonic() - last_spawn < 1.0:
                respawn_fails += 1
                delay = min(8.0, 0.1 * (2 ** min(respawn_fails, 7))) + random.uniform(0, 0.3)
                time.sleep(delay)
            else:
                respawn_fails = 0
            spawn_shell()

        # Apply a debounced resize once the burst has settled (see RESIZE_DEBOUNCE).
        # While one is pending, shorten the select timeout so we apply promptly.
        timeout = 1.0
        if pending_resize:
            if now >= resize_deadline:
                apply_resize()
            else:
                timeout = max(0.0, resize_deadline - now)

        # Determine which clients need write events for pending output
        for fd in list(client_outq):
            if fd in clients:
                try:
                    sel.modify(fd, selectors.EVENT_READ | selectors.EVENT_WRITE, 'client')
                except Exception:
                    pass

        try:
            events = sel.select(timeout=timeout)
        except InterruptedError:
            continue

        for key, mask in events:
            if key.data == 'server':
                try:
                    conn, _ = server.accept()
                    conn.setblocking(False)
                    fd = conn.fileno()
                    clients[fd] = conn
                    # Strip query REQUESTS from the replay so this fresh client
                    # doesn't re-answer a stale DA/CPR/color/mode probe (the answer
                    # would be injected into the shared PTY and echoed at the prompt).
                    replay = strip_terminal_queries(ring.read_all())
                    initial = b'\033[0m' + replay if replay else b''
                    if initial:
                        try:
                            sent = conn.send(initial)
                            if sent < len(initial):
                                client_outq[fd] = bytearray(initial[sent:])
                        except (BlockingIOError, InterruptedError):
                            client_outq[fd] = bytearray(initial)
                        except Exception:
                            remove_client(fd)
                            continue
                    sel.register(fd, selectors.EVENT_READ, 'client')
                except Exception:
                    pass

            elif key.data == 'pty':
                try:
                    data = os.read(pty_fd, 16384)
                except OSError as e:
                    if e.errno == errno.EIO:
                        continue
                    raise
                if data:
                    ring.write(data)
                    broadcast(data)

            elif key.data == 'client':
                fd = key.fd

                if mask & selectors.EVENT_WRITE:
                    flush_client_outq(fd)
                    if fd not in client_outq and fd in clients:
                        try:
                            sel.modify(fd, selectors.EVENT_READ, 'client')
                        except Exception:
                            pass

                if mask & selectors.EVENT_READ:
                    sock = clients.get(fd)
                    if not sock:
                        continue
                    try:
                        data = sock.recv(4096)
                    except Exception:
                        data = None
                    if not data:
                        remove_client(fd)
                        continue
                    if pty_fd >= 0:
                        # Write ALL the bytes: the master is non-blocking, so a
                        # large paste can short-write or raise EAGAIN — the old
                        # single os.write silently dropped the remainder. Loop on
                        # the unwritten tail, waiting (bounded) for writability.
                        mv = memoryview(data)
                        while mv:
                            try:
                                mv = mv[os.write(pty_fd, mv):]
                            except BlockingIOError:
                                if not select.select([], [pty_fd], [], 1.0)[1]:
                                    break   # not writable within 1s — give up, don't hang
                            except OSError:
                                break


# ---------------------------------------------------------------------------
# attach
# ---------------------------------------------------------------------------

def cmd_attach(instance):
    sock_path = f'/tmp/vibetop-session-{instance}.sock'
    size_path = f'/tmp/vibetop-session-{instance}.size'
    pid_path = f'/tmp/vibetop-session-{instance}.pid'

    sock = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
    # The serve daemon may still be creating its socket (systemd's After=
    # only orders process start, not readiness). Retry briefly instead of
    # dying — ttyd would otherwise show a dead terminal until its 3s
    # client-side reconnect.
    deadline = time.monotonic() + 3.0
    while True:
        try:
            sock.connect(sock_path)
            break
        except (FileNotFoundError, ConnectionRefusedError):
            if time.monotonic() >= deadline:
                raise
            time.sleep(0.05)

    stdin_fd = sys.stdin.fileno()
    stdout_fd = sys.stdout.fileno()

    def send_resize():
        try:
            rows, cols = get_pty_size(stdin_fd)
            # Write atomically (temp in the same dir + rename) so the serve
            # daemon's reader can never see a torn/empty file mid-write — a
            # partial read fell back to 24x80, momentarily shrinking the shell.
            # O_NOFOLLOW guards the predictable /tmp path against a symlink.
            tmp = f'{size_path}.{os.getpid()}.tmp'
            try:
                os.unlink(tmp)
            except FileNotFoundError:
                pass
            fd = os.open(tmp, os.O_WRONLY | os.O_CREAT | os.O_TRUNC | os.O_NOFOLLOW, 0o600)
            with os.fdopen(fd, 'w') as f:
                f.write(f'{rows} {cols}')
            os.replace(tmp, size_path)
            with open(pid_path) as f:
                pid = int(f.read().strip())
            os.kill(pid, signal.SIGUSR1)
        except Exception:
            pass

    send_resize()
    signal.signal(signal.SIGWINCH, lambda *_: send_resize())

    old_attrs = termios.tcgetattr(stdin_fd)
    attrs = termios.tcgetattr(stdin_fd)
    # Input: clear CR→NL conversion (ICRNL) so \r reaches apps as \r,
    # and disable XON/XOFF flow control (IXON) to pass Ctrl+S/Q through.
    attrs[0] &= ~(termios.ICRNL | termios.IXON | termios.ISTRIP | termios.INPCK | termios.BRKINT)
    # Local: raw mode (no echo, no canonical, no signals, no extended)
    attrs[3] &= ~(termios.ECHO | termios.ICANON | termios.ISIG | termios.IEXTEN)
    attrs[6][termios.VMIN] = 1
    attrs[6][termios.VTIME] = 0
    termios.tcsetattr(stdin_fd, termios.TCSADRAIN, attrs)

    try:
        import select as _sel
        while True:
            try:
                rlist, _, _ = _sel.select([stdin_fd, sock.fileno()], [], [])
            except InterruptedError:
                continue

            for fd in rlist:
                if fd == stdin_fd:
                    try:
                        data = os.read(stdin_fd, 4096)
                    except OSError:
                        data = b''
                    if not data:
                        return
                    try:
                        sock.sendall(data)
                    except Exception:
                        return
                else:
                    try:
                        data = sock.recv(16384)
                    except Exception:
                        data = b''
                    if not data:
                        return
                    write_all(stdout_fd, data)
    finally:
        termios.tcsetattr(stdin_fd, termios.TCSADRAIN, old_attrs)
        sock.close()


# ---------------------------------------------------------------------------
# main
# ---------------------------------------------------------------------------

def main():
    parser = argparse.ArgumentParser(description='Terminal session daemon')
    sub = parser.add_subparsers(dest='command')
    sub.required = True

    p = sub.add_parser('serve')
    p.add_argument('instance')

    p = sub.add_parser('attach')
    p.add_argument('instance')

    args = parser.parse_args()
    if args.command == 'serve':
        cmd_serve(args.instance)
    else:
        cmd_attach(args.instance)


if __name__ == '__main__':
    main()
