# Editor / OS cruft
*.swp
*~
.DS_Store
.idea/
.vscode/

# Local secrets / rendered configs (templates are tracked, rendered output is not)
*.local
.env
*.json.bak

# Cloudflare tunnel credentials (never commit)
*.json
!**/package.json
cert.pem
credentials.json

# Host-local service list (real hostnames/IPs live here, never committed).
# Only the generic example is tracked.
services.json
!landing/services.example.json

# Python bytecode cache
__pycache__/
*.pyc
