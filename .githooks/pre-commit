#!/usr/bin/env bash
#
# vibetop pre-commit — run the hermetic regression suite before a commit lands
# (~5s). Delegates to ./run-tests.sh (the single source of truth for which
# suites run), so the hook and CI never drift.
#
# Versioned in-repo (not .git/hooks) so it's shared. Enable it once per clone:
#   git config core.hooksPath .githooks
#
# Bypass for a single commit with `git commit --no-verify`, or set SKIP_TESTS=1.
# run-tests.sh self-skips any runner whose tool (pytest/node/shellcheck) isn't
# installed, so the hook never blocks a commit just because a tool is missing.
set -uo pipefail

root="$(git rev-parse --show-toplevel)" || exit 0
cd "$root" || exit 0

if [ "${SKIP_TESTS:-0}" = "1" ]; then
    echo "pre-commit: SKIP_TESTS=1 — skipping tests."
    exit 0
fi

if ! ./run-tests.sh; then
    echo "pre-commit: tests FAILED — commit aborted (override with --no-verify)." >&2
    exit 1
fi
echo "pre-commit: all tests passed."
